# Local application URLs
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:3001
VITE_API_BASE_URL=http://localhost:3001/api
PORT=3001
CLIENT_ORIGIN=http://localhost:5173
DEMO_MODE=true

# These VITE_* values are compiled into the browser bundle and are public.
# Enable them only for the fictional local dataset. Cloud/production builds
# must set VITE_SHOW_DEMO_ACCOUNTS=false and omit every VITE_DEMO_* value.
VITE_SHOW_DEMO_ACCOUNTS=true
VITE_DEMO_SUPER_ADMIN_EMAIL=admin@aifinora.com
VITE_DEMO_SUPER_ADMIN_PASSWORD=Admin@123
VITE_DEMO_HOSPITAL_CODE=akram-medical
VITE_DEMO_HOSPITAL_ADMIN_EMAIL=hospitaladmin@example.com
VITE_DEMO_HOSPITAL_ADMIN_PASSWORD=Hospital@123
VITE_DEMO_RECEPTIONIST_EMAIL=receptionist@example.com
VITE_DEMO_RECEPTIONIST_PASSWORD=Reception@123
VITE_DEMO_BILLING_EMAIL=billing@example.com
VITE_DEMO_BILLING_PASSWORD=Billing@123
VITE_DEMO_ACCOUNTANT_EMAIL=accountant@example.com
VITE_DEMO_ACCOUNTANT_PASSWORD=Accounts@123

# SQLite is used for the local SaaS demonstration. Replace the provider and URL
# through a reviewed migration before using PostgreSQL in production.
DATABASE_URL="file:./dev.db"

# This local-only value is rejected in production. Generate a unique random
# secret of at least 32 characters through the cloud secret manager.
JWT_SECRET=local-demo-change-this-secret
JWT_EXPIRES_IN=8h
REMEMBER_ME_EXPIRES_IN=30d
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

# Pluggable email boundary. Local simulation validates and reports a simulated
# outcome but never delivers or logs a message. Production defaults to disabled
# until a real provider plus durable outbox/worker is implemented.
EMAIL_PROVIDER=local_simulation

# Optional Safepay provider. Empty credentials keep the safe simulated flow only.
SAFEPAY_PUBLIC_KEY=
SAFEPAY_SECRET_KEY=
SAFEPAY_WEBHOOK_SECRET=
SAFEPAY_WEBHOOK_VERIFICATION_MODE=structural_hmac_demo
SAFEPAY_ENVIRONMENT=sandbox
SAFEPAY_DEMO_MODE=true
SAFEPAY_API_BASE_URL=
SAFEPAY_CREATE_LINK_URL=

# Demo-only bank instructions. Do not commit real banking details.
BANK_ACCOUNT_TITLE=AI Finora Demo Account
BANK_NAME=Demo Commercial Bank
BANK_IBAN=PK00DEMO0000000000000000

# Upload policy. Keep the reverse-proxy limit slightly above this value.
MAX_UPLOAD_BYTES=5242880
UPLOAD_DIR=
